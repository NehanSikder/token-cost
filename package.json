{
  "name": "token-cost",
  "version": "0.0.1",
  "description": "Compare what a piece of text costs to send across LLMs.",
  "type": "module",
  "bin": {
    "token-cost": "dist/cli.js"
  },
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "data"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "node dist/cli.js"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "llm",
    "tokens",
    "tokenizer",
    "cost",
    "pricing",
    "openai",
    "cli"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^26.1.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "js-tiktoken": "^1.0.21"
  }
}
